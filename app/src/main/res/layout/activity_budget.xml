<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF2F5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Phone Frame Container (max-width 400dp equivalent) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/phone_frame_bg"
            android:maxWidth="400dp"
            android:orientation="vertical">

            <!-- Settings Screen Content -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingTop="28dp"
                android:paddingEnd="24dp"
                android:paddingBottom="40dp">

                <!-- Logo Wrapper -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:gravity="center_horizontal"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="#0A2540"
                        android:orientation="horizontal"
                        android:paddingStart="24dp"
                        android:paddingTop="10dp"
                        android:paddingEnd="24dp"
                        android:paddingBottom="10dp"
                        app:cardCornerRadius="44dp"
                        style="@style/CardViewStyle">

                        <TextView
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:background="#2ECC71"
                            android:gravity="center"
                            android:text="$"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            app:cardCornerRadius="10dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:text="Cashflow Pro"
                            android:textColor="#FFFFFF"
                            android:textSize="23sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Screen Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:text="Budget Settings"
                    android:textColor="#0A2540"
                    android:textSize="29sp"
                    android:textStyle="normal|bold" />

                <!-- Settings Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:cardCornerRadius="32dp"
                    app:cardElevation="12dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardUseCompatPadding="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="22dp">

                        <!-- Monthly Budget Section -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:text="Monthly Budget"
                            android:textColor="#0A2540"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <!-- Total Monthly Budget Field -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="22dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:layout_marginBottom="6dp"
                                android:text="Total monthly budget (R)"
                                android:textColor="#3A4E66"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@drawable/input_background"
                                android:gravity="center_vertical"
                                android:orientation="horizontal"
                                android:paddingStart="20dp"
                                android:paddingTop="4dp"
                                android:paddingEnd="20dp"
                                android:paddingBottom="4dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginEnd="10dp"
                                    android:text="📊"
                                    android:textSize="19sp" />

                                <EditText
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:background="@null"
                                    android:gravity="start|center_vertical"
                                    android:hint="e.g., 5000"
                                    android:inputType="number"
                                    android:paddingTop="16dp"
                                    android:paddingBottom="16dp"
                                    android:text="5000"
                                    android:textColor="#1A2B3E"
                                    android:textSize="16sp" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Category Budget Limits Section -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:layout_marginBottom="12dp"
                            android:text="Category Budget Limits"
                            android:textColor="#0A2540"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <!-- Groceries Category -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:background="#F8FAFD"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="12dp"
                            android:paddingTop="6dp"
                            android:paddingEnd="18dp"
                            android:paddingBottom="6dp"
                            app:cardCornerRadius="60dp">

                            <TextView
                                android:layout_width="32dp"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:text="🛒"
                                android:textSize="21sp" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="12dp"
                                android:text="Groceries"
                                android:textColor="#0A2540"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="#FFFFFF"
                                android:gravity="center_vertical"
                                android:orientation="horizontal"
                                android:paddingStart="12dp"
                                android:paddingTop="6dp"
                                android:paddingEnd="12dp"
                                android:paddingBottom="6dp"
                                app:cardCornerRadius="40dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="R"
                                    android:textColor="#5D738B"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />

                                <EditText
                                    android:layout_width="70dp"
                                    android:layout_height="wrap_content"
                                    android:background="@null"
                                    android:gravity="end"
                                    android:inputType="number"
                                    android:text="1500"
                                    android:textColor="#0A2540"
                                    android:textSize="15sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Transport Category -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:background="#F8FAFD"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="12dp"
                            android:paddingTop="6dp"
                            android:paddingEnd="18dp"
                            android:paddingBottom="6dp"
                            app:cardCornerRadius="60dp">

                            <TextView
                                android:layout_width="32dp"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:text="🚗"
                                android:textSize="21sp" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="12dp"
                                android:text="Transport"
                                android:textColor="#0A2540"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="#FFFFFF"
                                android:gravity="center_vertical"
                                android:orientation="horizontal"
                                android:paddingStart="12dp"
                                android:paddingTop="6dp"
                                android:paddingEnd="12dp"
                                android:paddingBottom="6dp"
                                app:cardCornerRadius="40dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="R"
                                    android:textColor="#5D738B"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />

                                <EditText
                                    android:layout_width="70dp"
                                    android:layout_height="wrap_content"
                                    android:background="@null"
                                    android:gravity="end"
                                    android:inputType="number"
                                    android:text="800"
                                    android:textColor="#0A2540"
                                    android:textSize="15sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Entertainment Category -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:background="#F8FAFD"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="12dp"
                            android:paddingTop="6dp"
                            android:paddingEnd="18dp"
                            android:paddingBottom="6dp"
                            app:cardCornerRadius="60dp">

                            <TextView
                                android:layout_width="32dp"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:text="🍿"
                                android:textSize="21sp" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="12dp"
                                android:text="Entertainment"
                                android:textColor="#0A2540"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="#FFFFFF"
                                android:gravity="center_vertical"
                                android:orientation="horizontal"
                                android:paddingStart="12dp"
                                android:paddingTop="6dp"
                                android:paddingEnd="12dp"
                                android:paddingBottom="6dp"
                                app:cardCornerRadius="40dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="R"
                                    android:textColor="#5D738B"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />

                                <EditText
                                    android:layout_width="70dp"
                                    android:layout_height="wrap_content"
                                    android:background="@null"
                                    android:gravity="end"
                                    android:inputType="number"
                                    android:text="900"
                                    android:textColor="#0A2540"
                                    android:textSize="15sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Dining Out Category -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:background="#F8FAFD"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="12dp"
                            android:paddingTop="6dp"
                            android:paddingEnd="18dp"
                            android:paddingBottom="6dp"
                            app:cardCornerRadius="60dp">

                            <TextView
                                android:layout_width="32dp"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:text="🍽️"
                                android:textSize="21sp" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="12dp"
                                android:text="Dining out"
                                android:textColor="#0A2540"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="#FFFFFF"
                                android:gravity="center_vertical"
                                android:orientation="horizontal"
                                android:paddingStart="12dp"
                                android:paddingTop="6dp"
                                android:paddingEnd="12dp"
                                android:paddingBottom="6dp"
                                app:cardCornerRadius="40dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="R"
                                    android:textColor="#5D738B"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />

                                <EditText
                                    android:layout_width="70dp"
                                    android:layout_height="wrap_content"
                                    android:background="@null"
                                    android:gravity="end"
                                    android:inputType="number"
                                    android:text="600"
                                    android:textColor="#0A2540"
                                    android:textSize="15sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Utilities Category -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="18dp"
                            android:background="#F8FAFD"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="12dp"
                            android:paddingTop="6dp"
                            android:paddingEnd="18dp"
                            android:paddingBottom="6dp"
                            app:cardCornerRadius="60dp">

                            <TextView
                                android:layout_width="32dp"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:text="💡"
                                android:textSize="21sp" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="12dp"
                                android:text="Utilities"
                                android:textColor="#0A2540"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="#FFFFFF"
                                android:gravity="center_vertical"
                                android:orientation="horizontal"
                                android:paddingStart="12dp"
                                android:paddingTop="6dp"
                                android:paddingEnd="12dp"
                                android:paddingBottom="6dp"
                                app:cardCornerRadius="40dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="R"
                                    android:textColor="#5D738B"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />

                                <EditText
                                    android:layout_width="70dp"
                                    android:layout_height="wrap_content"
                                    android:background="@null"
                                    android:gravity="end"
                                    android:inputType="number"
                                    android:text="1000"
                                    android:textColor="#0A2540"
                                    android:textSize="15sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Save Settings Button -->
                        <Button
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:layout_marginBottom="18dp"
                            android:background="@drawable/primary_button_background"
                            android:backgroundTint="#0A2540"
                            android:padding="18dp"
                            android:text="💾 Save Settings"
                            android:textAllCaps="false"
                            android:textColor="#FFFFFF"
                            android:textSize="19sp"
                            android:textStyle="bold" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Summary Hints (Success/Warning) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_horizontal"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="#E2F7E9"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="18dp"
                        android:paddingTop="6dp"
                        android:paddingEnd="18dp"
                        android:paddingBottom="6dp"
                        app:cardCornerRadius="40dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="5dp"
                            android:text="✓"
                            android:textColor="#1D8844"
                            android:textSize="17sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="R1,800 remaining"
                            android:textColor="#1D8844"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:background="#FEEAE8"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="18dp"
                        android:paddingTop="6dp"
                        android:paddingEnd="18dp"
                        android:paddingBottom="6dp"
                        app:cardCornerRadius="40dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="5dp"
                            android:text="!"
                            android:textColor="#C73B3B"
                            android:textSize="17sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Entertainment +50%"
                            android:textColor="#C73B3B"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Footer Text -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:gravity="center_horizontal"
                    android:text="Adjust limits • changes auto-save demo"
                    android:textColor="#A7B8C9"
                    android:textSize="13sp" />

            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>