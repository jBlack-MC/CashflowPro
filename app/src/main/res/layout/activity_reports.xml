<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#EEF2F5">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- Phone frame outer container -->
        <androidx.cardview.widget.CardView
            android:id="@+id/phoneFrame"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:cardCornerRadius="36dp"
            app:cardElevation="12dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Logo Wrapper -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="20dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="#0A2540"
                        android:paddingStart="24dp"
                        android:paddingEnd="24dp"
                        android:paddingTop="10dp"
                        android:paddingBottom="10dp"
                        android:elevation="6dp"
                        android:backgroundTint="#0A2540">

                        <TextView
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:text="$"
                            android:textSize="20sp"
                            android:textColor="#FFFFFF"
                            android:gravity="center"
                            android:background="#2ECC71"
                            android:padding="5dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cashflow Pro"
                            android:textSize="23sp"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:letterSpacing="0.02"
                            android:layout_marginStart="10dp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Reports"
                    android:textSize="28sp"
                    android:textColor="#0A2540"
                    android:textStyle="normal"
                    android:layout_marginBottom="24dp"
                    android:letterSpacing="-0.01" />

                <!-- Period Selector Chips -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="24dp">

                    <!-- Week Chip -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="#F1F6FA"
                        android:paddingStart="22dp"
                        android:paddingEnd="22dp"
                        android:paddingTop="10dp"
                        android:paddingBottom="10dp"
                        android:layout_marginEnd="10dp"
                        android:backgroundTint="#F1F6FA">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Week"
                            android:textSize="14sp"
                            android:textColor="#3A4E66"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Month Chip (Active) -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="#0A2540"
                        android:paddingStart="22dp"
                        android:paddingEnd="22dp"
                        android:paddingTop="10dp"
                        android:paddingBottom="10dp"
                        android:layout_marginEnd="10dp"
                        android:backgroundTint="#0A2540"
                        android:elevation="4dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Month"
                            android:textSize="14sp"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Year Chip -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="#F1F6FA"
                        android:paddingStart="22dp"
                        android:paddingEnd="22dp"
                        android:paddingTop="10dp"
                        android:paddingBottom="10dp"
                        android:backgroundTint="#F1F6FA">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Year"
                            android:textSize="14sp"
                            android:textColor="#3A4E66"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Summary Cards Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="28dp">

                    <!-- Income Card -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="6dp"
                        app:cardBackgroundColor="#F5F9FF">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Income"
                                android:textSize="12sp"
                                android:textColor="#5D738B"
                                android:textStyle="bold"
                                android:textAllCaps="true"
                                android:letterSpacing="0.02" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="R8,400"
                                android:textSize="22sp"
                                android:textColor="#0A2540"
                                android:textStyle="bold"
                                android:layout_marginTop="4dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="↓ 2%"
                                android:textSize="13sp"
                                android:textColor="#2ECC71"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Expenses Card -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:layout_marginEnd="6dp"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="6dp"
                        app:cardBackgroundColor="#F5F9FF">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Expenses"
                                android:textSize="12sp"
                                android:textColor="#5D738B"
                                android:textStyle="bold"
                                android:textAllCaps="true"
                                android:letterSpacing="0.02" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="R5,280"
                                android:textSize="22sp"
                                android:textColor="#0A2540"
                                android:textStyle="bold"
                                android:layout_marginTop="4dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="↑ 8%"
                                android:textSize="13sp"
                                android:textColor="#C73B3B"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Savings Card -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="6dp"
                        app:cardBackgroundColor="#F5F9FF">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Savings"
                                android:textSize="12sp"
                                android:textColor="#5D738B"
                                android:textStyle="bold"
                                android:textAllCaps="true"
                                android:letterSpacing="0.02" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="R3,120"
                                android:textSize="22sp"
                                android:textColor="#0A2540"
                                android:textStyle="bold"
                                android:layout_marginTop="4dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="↓ 5%"
                                android:textSize="13sp"
                                android:textColor="#2ECC71"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <!-- Chart Card (Spending by Category) -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="28dp"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="8dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="22dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Spending by Category"
                            android:textSize="16sp"
                            android:textColor="#0A2540"
                            android:textStyle="bold"
                            android:layout_marginBottom="20dp" />

                        <!-- Bar Chart Row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="bottom">

                            <!-- Groceries Bar -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center_horizontal"
                                android:layout_marginEnd="4dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="🛒"
                                    android:textSize="16sp"
                                    android:layout_marginBottom="6dp" />

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="120dp"
                                    android:background="#E9EFF6"
                                    android:orientation="vertical"
                                    android:gravity="bottom"
                                    android:clipChildren="false">

                                    <View
                                        android:layout_width="match_parent"
                                        android:layout_height="96dp"
                                        android:background="#0A2540" />
                                </LinearLayout>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="R1,200"
                                    android:textSize="12sp"
                                    android:textColor="#1A2B3E"
                                    android:textStyle="bold"
                                    android:layout_marginTop="6dp" />
                            </LinearLayout>

                            <!-- Transport Bar -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center_horizontal"
                                android:layout_marginStart="4dp"
                                android:layout_marginEnd="4dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="🚗"
                                    android:textSize="16sp"
                                    android:layout_marginBottom="6dp" />

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="120dp"
                                    android:background="#E9EFF6"
                                    android:orientation="vertical"
                                    android:gravity="bottom"
                                    android:clipChildren="false">

                                    <View
                                        android:layout_width="match_parent"
                                        android:layout_height="78dp"
                                        android:background="#2ECC71" />
                                </LinearLayout>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="R650"
                                    android:textSize="12sp"
                                    android:textColor="#1A2B3E"
                                    android:textStyle="bold"
                                    android:layout_marginTop="6dp" />
                            </LinearLayout>

                            <!-- Entertainment Bar (Red/Overspent) -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center_horizontal"
                                android:layout_marginStart="4dp"
                                android:layout_marginEnd="4dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="🍿"
                                    android:textSize="16sp"
                                    android:layout_marginBottom="6dp" />

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="120dp"
                                    android:background="#E9EFF6"
                                    android:orientation="vertical"
                                    android:gravity="bottom"
                                    android:clipChildren="false">

                                    <View
                                        android:layout_width="match_parent"
                                        android:layout_height="120dp"
                                        android:background="#C73B3B" />
                                </LinearLayout>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="R1,350"
                                    android:textSize="12sp"
                                    android:textColor="#1A2B3E"
                                    android:textStyle="bold"
                                    android:layout_marginTop="6dp" />
                            </LinearLayout>

                            <!-- Dining Bar -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center_horizontal"
                                android:layout_marginStart="4dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="🍽️"
                                    android:textSize="16sp"
                                    android:layout_marginBottom="6dp" />

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="120dp"
                                    android:background="#E9EFF6"
                                    android:orientation="vertical"
                                    android:gravity="bottom"
                                    android:clipChildren="false">

                                    <View
                                        android:layout_width="match_parent"
                                        android:layout_height="54dp"
                                        android:background="#0A2540" />
                                </LinearLayout>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="R480"
                                    android:textSize="12sp"
                                    android:textColor="#1A2B3E"
                                    android:textStyle="bold"
                                    android:layout_marginTop="6dp" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Category Breakdown Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Category Breakdown"
                    android:textSize="16sp"
                    android:textColor="#0A2540"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <!-- Category Breakdown List -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="28dp">

                    <!-- Groceries Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="#F8FAFD"
                        android:padding="12dp"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="36dp"
                            android:layout_height="wrap_content"
                            android:text="🛒"
                            android:textSize="18sp"
                            android:gravity="center" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Groceries"
                                android:textSize="14sp"
                                android:textColor="#0A2540"
                                android:textStyle="bold" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Budget R1,500  •  80% used"
                                    android:textSize="11sp"
                                    android:textColor="#5D738B" />
                            </LinearLayout>
                        </LinearLayout>

                        <TextView
                            android:layout_width="70dp"
                            android:layout_height="wrap_content"
                            android:text="R1,200"
                            android:textSize="16sp"
                            android:textColor="#0A2540"
                            android:textStyle="bold"
                            android:gravity="end"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:layout_width="55dp"
                            android:layout_height="wrap_content"
                            android:text="-3%"
                            android:textSize="13sp"
                            android:textColor="#2ECC71"
                            android:textStyle="bold"
                            android:gravity="end" />
                    </LinearLayout>

                    <!-- Transport Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="#F8FAFD"
                        android:padding="12dp"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="36dp"
                            android:layout_height="wrap_content"
                            android:text="🚗"
                            android:textSize="18sp"
                            android:gravity="center" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Transport"
                                android:textSize="14sp"
                                android:textColor="#0A2540"
                                android:textStyle="bold" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Budget R800  •  81% used"
                                    android:textSize="11sp"
                                    android:textColor="#5D738B" />
                            </LinearLayout>
                        </LinearLayout>

                        <TextView
                            android:layout_width="70dp"
                            android:layout_height="wrap_content"
                            android:text="R650"
                            android:textSize="16sp"
                            android:textColor="#0A2540"
                            android:textStyle="bold"
                            android:gravity="end"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:layout_width="55dp"
                            android:layout_height="wrap_content"
                            android:text="-5%"
                            android:textSize="13sp"
                            android:textColor="#2ECC71"
                            android:textStyle="bold"
                            android:gravity="end" />
                    </LinearLayout>

                    <!-- Entertainment Row (Overspent) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="#F8FAFD"
                        android:padding="12dp"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="36dp"
                            android:layout_height="wrap_content"
                            android:text="🍿"
                            android:textSize="18sp"
                            android:gravity="center" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Entertainment"
                                android:textSize="14sp"
                                android:textColor="#0A2540"
                                android:textStyle="bold" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Budget R900  •  150% used"
                                    android:textSize="11sp"
                                    android:textColor="#5D738B" />
                            </LinearLayout>
                        </LinearLayout>

                        <TextView
                            android:layout_width="70dp"
                            android:layout_height="wrap_content"
                            android:text="R1,350"
                            android:textSize="16sp"
                            android:textColor="#0A2540"
                            android:textStyle="bold"
                            android:gravity="end"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:layout_width="55dp"
                            android:layout_height="wrap_content"
                            android:text="+22%"
                            android:textSize="13sp"
                            android:textColor="#C73B3B"
                            android:textStyle="bold"
                            android:gravity="end" />
                    </LinearLayout>

                    <!-- Dining Out Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="#F8FAFD"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="36dp"
                            android:layout_height="wrap_content"
                            android:text="🍽️"
                            android:textSize="18sp"
                            android:gravity="center" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Dining out"
                                android:textSize="14sp"
                                android:textColor="#0A2540"
                                android:textStyle="bold" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Budget R600  •  80% used"
                                    android:textSize="11sp"
                                    android:textColor="#5D738B" />
                            </LinearLayout>
                        </LinearLayout>

                        <TextView
                            android:layout_width="70dp"
                            android:layout_height="wrap_content"
                            android:text="R480"
                            android:textSize="16sp"
                            android:textColor="#0A2540"
                            android:textStyle="bold"
                            android:gravity="end"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:layout_width="55dp"
                            android:layout_height="wrap_content"
                            android:text="-2%"
                            android:textSize="13sp"
                            android:textColor="#2ECC71"
                            android:textStyle="bold"
                            android:gravity="end" />
                    </LinearLayout>
                </LinearLayout>

                <!-- View Full Report Button -->
                <Button
                    android:id="@+id/btnFullReport"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📄 View Full Report"
                    android:textSize="16sp"
                    android:textColor="#0A2540"
                    android:textStyle="bold"
                    android:background="@android:color/transparent"
                    android:backgroundTint="@null"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="16dp"
                    android:stateListAnimator="@null"
                    style="@style/Widget.Material3.Button.OutlinedButton" />

                <!-- Hints Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:background="#E2F7E9"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:layout_marginEnd="12dp"
                        android:backgroundTint="#E2F7E9">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✓"
                            android:textSize="16sp"
                            android:textColor="#1D8844"
                            android:layout_marginEnd="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="3 categories on track"
                            android:textSize="13sp"
                            android:textColor="#1D8844"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:background="#FFEAE8"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:backgroundTint="#FFEAE8">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="!"
                            android:textSize="16sp"
                            android:textColor="#C73B3B"
                            android:layout_marginEnd="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
