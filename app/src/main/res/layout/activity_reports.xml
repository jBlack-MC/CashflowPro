<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Monthly Report"
            app:titleTextColor="@color/white"
            app:navigationIcon="@android:drawable/ic_menu_revert"
            app:navigationIconTint="@color/white" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <com.google.android.material.card.MaterialCardView
                style="@style/AppCardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:id="@+id/reportContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:id="@+id/tvReportMonth"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="October 2026 Summary"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="24dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvTotalSpending"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Total Spending: R0.00"
                            android:textSize="16sp"
                            android:layout_marginBottom="12dp" />

                        <TextView
                            android:id="@+id/tvHighestCategory"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Highest Category: None"
                            android:textSize="16sp"
                            android:layout_marginBottom="12dp" />

                        <TextView
                            android:id="@+id/tvLowestCategory"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Lowest Category: None"
                            android:textSize="16sp"
                            android:layout_marginBottom="12dp" />

                        <TextView
                            android:id="@+id/tvMoneySaved"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Money Saved: R0.00"
                            android:textSize="16sp"
                            android:textColor="@color/success_dark"
                            android:textStyle="bold"
                            android:layout_marginBottom="12dp" />

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <Button
                android:id="@+id/btnExportPdf"
                style="@style/AppButtonPrimary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Export as PDF" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
