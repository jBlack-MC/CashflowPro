<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_variant">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface_variant"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Monthly Report"
            app:titleTextColor="@color/text_primary"
            app:navigationIcon="@android:drawable/ic_menu_revert"
            app:navigationIconTint="@color/text_primary"
            app:titleCentered="true" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <com.google.android.material.card.MaterialCardView
                style="@style/AppCardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:strokeWidth="0dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:id="@+id/reportContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:id="@+id/tvReportMonth"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Financial Summary"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="24dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvTotalSpending"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Total Expenses: R0.00"
                            android:textSize="16sp"
                            android:layout_marginBottom="16dp"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:id="@+id/tvHighestCategory"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Highest Category: None"
                            android:textSize="16sp"
                            android:layout_marginBottom="16dp"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:id="@+id/tvLowestCategory"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Lowest Category: None"
                            android:textSize="16sp"
                            android:layout_marginBottom="16dp"
                            android:textColor="@color/text_primary" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/divider"
                            android:layout_marginBottom="16dp" />

                        <TextView
                            android:id="@+id/tvMoneySaved"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Net Savings: R0.00"
                            android:textSize="18sp"
                            android:textColor="@color/success_dark"
                            android:textStyle="bold" />

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnExportPdf"
                style="@style/AppButtonPrimary"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Export as PDF Document"
                app:icon="@android:drawable/ic_menu_save"
                app:iconGravity="textStart" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnShare"
                style="@style/AppButtonOutlined"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Share Report"
                android:layout_marginTop="16dp"
                app:icon="@android:drawable/ic_menu_share"
                app:iconGravity="textStart" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
