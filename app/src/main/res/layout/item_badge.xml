<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/AppCardView"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp">

    <LinearLayout
        android:id="@+id/badgeRoot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:alpha="0.5"> <!-- Greyed out if locked -->

        <TextView
            android:id="@+id/tvBadgeIcon"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/card_bg_light"
            android:gravity="center"
            android:text="🥉"
            android:textSize="32sp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:id="@+id/tvBadgeName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Beginner Saver"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/tvBadgeDescription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Logged your first expense!"
                android:textSize="12sp"
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/tvUnlockDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Locked"
                android:textSize="10sp"
                android:textStyle="italic"
                android:layout_marginTop="4dp"
                android:textColor="@color/primary" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
