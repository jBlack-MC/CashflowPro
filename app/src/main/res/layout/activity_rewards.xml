<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#EEF2F5">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- Phone frame outer container -->
        <androidx.cardview.widget.CardView
            android:id="@+id/phoneFrame"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:cardCornerRadius="36dp"
            app:cardElevation="12dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Logo Wrapper -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="20dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="#0A2540"
                        android:paddingStart="24dp"
                        android:paddingEnd="24dp"
                        android:paddingTop="10dp"
                        android:paddingBottom="10dp"
                        android:elevation="6dp"
                        android:backgroundTint="#0A2540">

                        <ImageView
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:src="@drawable/logo"
                            android:contentDescription="Logo" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cashflow Pro"
                            android:textSize="23sp"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:letterSpacing="0.02"
                            android:layout_marginStart="10dp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rewards"
                    android:textSize="28sp"
                    android:textColor="#0A2540"
                    android:textStyle="normal"
                    android:layout_marginBottom="24dp"
                    android:letterSpacing="-0.01" />

                <!-- Points Summary Card (Gradient) -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="28dp"
                    app:cardCornerRadius="32dp"
                    app:cardElevation="12dp"
                    app:cardBackgroundColor="@android:color/transparent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="space_between"
                        android:background="@drawable/points_gradient_bg"
                        android:padding="22dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Your points"
                                android:textSize="14sp"
                                android:textColor="#FFFFFF"
                                android:alpha="0.8"
                                android:letterSpacing="0.02" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="2,450"
                                android:textSize="35sp"
                                android:textColor="#FFFFFF"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="#26FFFFFF"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:paddingTop="12dp"
                            android:paddingBottom="12dp"
                            android:backgroundTint="#26FFFFFF">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="⚡ Level 4"
                                android:textSize="16sp"
                                android:textColor="#FFFFFF"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Badges Grid -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="28dp">

                    <!-- Badge 1: Budget Master (Unlocked) -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        app:cardCornerRadius="28dp"
                        app:cardElevation="8dp"
                        app:cardBackgroundColor="#FFFFFF">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="20dp">

                            <!-- Badge Icon -->
                            <LinearLayout
                                android:layout_width="60dp"
                                android:layout_height="60dp"
                                android:gravity="center"
                                android:background="#0A2540">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="👑"
                                    android:textSize="28sp" />
                            </LinearLayout>

                            <!-- Badge Details -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="18dp">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="space_between"
                                    android:layout_marginBottom="8dp">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Budget Master"
                                        android:textSize="16sp"
                                        android:textColor="#0A2540"
                                        android:textStyle="bold" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Unlocked"
                                        android:textSize="12sp"
                                        android:textColor="#1D8844"
                                        android:textStyle="bold"
                                        android:background="#E2F7E9"
                                        android:paddingStart="12dp"
                                        android:paddingEnd="12dp"
                                        android:paddingTop="4dp"
                                        android:paddingBottom="4dp"
                                        android:backgroundTint="#E2F7E9" />
                                </LinearLayout>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Stick to budget for 30 days"
                                    android:textSize="13sp"
                                    android:textColor="#5D738B"
                                    android:layout_marginBottom="12dp" />

                                <!-- Progress Bar -->
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical">

                                    <LinearLayout
                                        android:layout_width="0dp"
                                        android:layout_height="8dp"
                                        android:layout_weight="1"
                                        android:background="#E0E9F2">

                                        <View
                                            android:layout_width="match_parent"
                                            android:layout_height="match_parent"
                                            android:background="#2ECC71" />
                                    </LinearLayout>

                                    <TextView
                                        android:layout_width="45dp"
                                        android:layout_height="wrap_content"
                                        android:text="30/30"
                                        android:textSize="12sp"
                                        android:textColor="#0A2540"
                                        android:textStyle="bold"
                                        android:gravity="end"
                                        android:layout_marginStart="8dp" />
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Badge 2: No Overspending (Unlocked) -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        app:cardCornerRadius="28dp"
                        app:cardElevation="8dp"
                        app:cardBackgroundColor="#FFFFFF">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="20dp">

                            <LinearLayout
                                android:layout_width="60dp"
                                android:layout_height="60dp"
                                android:gravity="center"
                                android:background="#0A2540">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="✅"
                                    android:textSize="28sp" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="18dp">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="space_between"
                                    android:layout_marginBottom="8dp">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="No Overspending"
                                        android:textSize="16sp"
                                        android:textColor="#0A2540"
                                        android:textStyle="bold" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Unlocked"
                                        android:textSize="12sp"
                                        android:textColor="#1D8844"
                                        android:textStyle="bold"
                                        android:background="#E2F7E9"
                                        android:paddingStart="12dp"
                                        android:paddingEnd="12dp"
                                        android:paddingTop="4dp"
                                        android:paddingBottom="4dp"
                                        android:backgroundTint="#E2F7E9" />
                                </LinearLayout>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="All categories within limit"
                                    android:textSize="13sp"
                                    android:textColor="#5D738B"
                                    android:layout_marginBottom="12dp" />

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical">

                                    <LinearLayout
                                        android:layout_width="0dp"
                                        android:layout_height="8dp"
                                        android:layout_weight="1"
                                        android:background="#E0E9F2">

                                        <View
                                            android:layout_width="match_parent"
                                            android:layout_height="match_parent"
                                            android:background="#2ECC71" />
                                    </LinearLayout>

                                    <TextView
                                        android:layout_width="45dp"
                                        android:layout_height="wrap_content"
                                        android:text="5/5"
                                        android:textSize="12sp"
                                        android:textColor="#0A2540"
                                        android:textStyle="bold"
                                        android:gravity="end"
                                        android:layout_marginStart="8dp" />
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Badge 3: 7-Day Streak (Locked - In Progress) -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        app:cardCornerRadius="28dp"
                        app:cardElevation="8dp"
                        app:cardBackgroundColor="#FFFFFF">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="20dp">

                            <LinearLayout
                                android:layout_width="60dp"
                                android:layout_height="60dp"
                                android:gravity="center"
                                android:background="#E9EFF6">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="🔥"
                                    android:textSize="28sp"
                                    android:alpha="0.7" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="18dp">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="space_between"
                                    android:layout_marginBottom="8dp">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="7-Day Streak"
                                        android:textSize="16sp"
                                        android:textColor="#0A2540"
                                        android:textStyle="bold" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Locked"
                                        android:textSize="12sp"
                                        android:textColor="#7F95AF"
                                        android:textStyle="bold"
                                        android:background="#F0F3F7"
                                        android:paddingStart="12dp"
                                        android:paddingEnd="12dp"
                                        android:paddingTop="4dp"
                                        android:paddingBottom="4dp"
                                        android:backgroundTint="#F0F3F7" />
                                </LinearLayout>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Log expenses 7 days in a row"
                                    android:textSize="13sp"
                                    android:textColor="#5D738B"
                                    android:layout_marginBottom="12dp" />

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical">

                                    <LinearLayout
                                        android:layout_width="0dp"
                                        android:layout_height="8dp"
                                        android:layout_weight="1"
                                        android:background="#E0E9F2">

                                        <View
                                            android:layout_width="0dp"
                                            android:layout_height="match_parent"
                                            android:layout_weight="71"
                                            android:background="#0A2540" />
                                    </LinearLayout>

                                    <TextView
                                        android:layout_width="45dp"
                                        android:layout_height="wrap_content"
                                        android:text="5/7"
                                        android:textSize="12sp"
                                        android:textColor="#0A2540"
                                        android:textStyle="bold"
                                        android:gravity="end"
                                        android:layout_marginStart="8dp" />
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Badge 4: Saver Extraordinaire (Locked) -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="28dp"
                        app:cardElevation="8dp"
                        app:cardBackgroundColor="#FFFFFF">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="20dp">

                            <LinearLayout
                                android:layout_width="60dp"
                                android:layout_height="60dp"
                                android:gravity="center"
                                android:background="#E9EFF6">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="🏆"
                                    android:textSize="28sp"
                                    android:alpha="0.7" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="18dp">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="space_between"
                                    android:layout_marginBottom="8dp">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Saver Extraordinaire"
                                        android:textSize="16sp"
                                        android:textColor="#0A2540"
                                        android:textStyle="bold" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Locked"
                                        android:textSize="12sp"
                                        android:textColor="#7F95AF"
                                        android:textStyle="bold"
                                        android:background="#F0F3F7"
                                        android:paddingStart="12dp"
                                        android:paddingEnd="12dp"
                                        android:paddingTop="4dp"
                                        android:paddingBottom="4dp"
                                        android:backgroundTint="#F0F3F7" />
                                </LinearLayout>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Save 20% of income for 3 months"
                                    android:textSize="13sp"
                                    android:textColor="#5D738B"
                                    android:layout_marginBottom="12dp" />

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical">

                                    <LinearLayout
                                        android:layout_width="0dp"
                                        android:layout_height="8dp"
                                        android:layout_weight="1"
                                        android:background="#E0E9F2">

                                        <View
                                            android:layout_width="0dp"
                                            android:layout_height="match_parent"
                                            android:layout_weight="33"
                                            android:background="#C73B3B" />
                                    </LinearLayout>

                                    <TextView
                                        android:layout_width="45dp"
                                        android:layout_height="wrap_content"
                                        android:text="1/3"
                                        android:textSize="12sp"
                                        android:textColor="#0A2540"
                                        android:textStyle="bold"
                                        android:gravity="end"
                                        android:layout_marginStart="8dp" />
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <!-- Next Rewards Section -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Coming soon"
                    android:textSize="16sp"
                    android:textColor="#0A2540"
                    android:textStyle="bold"
                    android:layout_marginStart="8dp"
                    android:layout_marginBottom="16dp" />

                <!-- Horizontal Scroll Rewards -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:layout_marginBottom="28dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingStart="4dp"
                        android:paddingEnd="4dp">

                        <!-- Reward 1 -->
                        <androidx.cardview.widget.CardView
                            android:layout_width="110dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="12dp"
                            app:cardCornerRadius="28dp"
                            app:cardElevation="6dp"
                            app:cardBackgroundColor="#F8FAFD">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="16dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="🎯"
                                    android:textSize="32sp"
                                    android:layout_marginBottom="8dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Early Bird"
                                    android:textSize="13sp"
                                    android:textColor="#0A2540"
                                    android:textStyle="bold"
                                    android:layout_marginBottom="4dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Log before 9am"
                                    android:textSize="11sp"
                                    android:textColor="#5D738B"
                                    android:gravity="center" />
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                        <!-- Reward 2 -->
                        <androidx.cardview.widget.CardView
                            android:layout_width="110dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="12dp"
                            app:cardCornerRadius="28dp"
                            app:cardElevation="6dp"
                            app:cardBackgroundColor="#F8FAFD">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="16dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="📊"
                                    android:textSize="32sp"
                                    android:layout_marginBottom="8dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Analyst"
                                    android:textSize="13sp"
                                    android:textColor="#0A2540"
                                    android:textStyle="bold"
                                    android:layout_marginBottom="4dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Check reports 10x"
                                    android:textSize="11sp"
                                    android:textColor="#5D738B"
                                    android:gravity="center" />
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                        <!-- Reward 3 -->
                        <androidx.cardview.widget.CardView
                            android:layout_width="110dp"
                            android:layout_height="wrap_content"
                            app:cardCornerRadius="28dp"
                            app:cardElevation="6dp"
                            app:cardBackgroundColor="#F8FAFD">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="16dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="💎"
                                    android:textSize="32sp"
                                    android:layout_marginBottom="8dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Diamond"
                                    android:textSize="13sp"
                                    android:textColor="#0A2540"
                                    android:textStyle="bold"
                                    android:layout_marginBottom="4dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Level 10"
                                    android:textSize="11sp"
                                    android:textColor="#5D738B"
                                    android:gravity="center" />
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>
                    </LinearLayout>
                </HorizontalScrollView>

                <!-- Hints Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:background="#E2F7E9"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:layout_marginEnd="12dp"
                        android:backgroundTint="#E2F7E9">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✓"
                            android:textSize="16sp"
                            android:textColor="#1D8844"
                            android:layout_marginEnd="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="2 badges unlocked"
                            android:textSize="13sp"
                            android:textColor="#1D8844"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:background="#FFEAE8"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:backgroundTint="#FFEAE8">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="!"
                            android:textSize="16sp"
                            android:textColor="#C73B3B"
                            android:layout_marginEnd="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="50 pts to next"
