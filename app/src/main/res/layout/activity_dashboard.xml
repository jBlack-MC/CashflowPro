<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#EEF2F5">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- Phone frame outer container -->
        <androidx.cardview.widget.CardView
            android:id="@+id/phoneFrame"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:cardCornerRadius="36dp"
            app:cardElevation="12dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Logo Wrapper -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="20dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="#0A2540"
                        android:paddingStart="24dp"
                        android:paddingEnd="24dp"
                        android:paddingTop="10dp"
                        android:paddingBottom="10dp"
                        android:elevation="6dp"
                        android:backgroundTint="#0A2540">

                        <TextView
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:text="$"
                            android:textSize="20sp"
                            android:textColor="#FFFFFF"
                            android:gravity="center"
                            android:background="#2ECC71"
                            android:padding="5dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cashflow Pro"
                            android:textSize="23sp"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:letterSpacing="0.02"
                            android:layout_marginStart="10dp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dashboard"
                    android:textSize="28sp"
                    android:textColor="#0A2540"
                    android:textStyle="normal"
                    android:layout_marginBottom="24dp"
                    android:letterSpacing="-0.01" />

                <!-- Summary Row: Total Budget, Spent, Remaining -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="24dp">

                    <!-- Total Budget Card -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="4dp"
                        app:cardBackgroundColor="#F5F9FF">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Total budget"
                                android:textSize="12sp"
                                android:textColor="#5D738B"
                                android:textStyle="bold"
                                android:letterSpacing="0.02"
                                android:textAllCaps="true" />

                            <TextView
                                android:id="@+id/tvTotalBudget"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="R5,000"
                                android:textSize="22sp"
                                android:textColor="#0A2540"
                                android:textStyle="bold"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Spent Card -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:layout_marginEnd="6dp"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="4dp"
                        app:cardBackgroundColor="#F5F9FF">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Spent"
                                android:textSize="12sp"
                                android:textColor="#5D738B"
                                android:textStyle="bold"
                                android:letterSpacing="0.02"
                                android:textAllCaps="true" />

                            <TextView
                                android:id="@+id/tvTotalSpent"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="R0"
                                android:textSize="22sp"
                                android:textColor="#0A2540"
                                android:textStyle="bold"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Remaining Card (Green highlight) -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="4dp"
                        app:cardBackgroundColor="#F5F9FF">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Remaining"
                                android:textSize="12sp"
                                android:textColor="#5D738B"
                                android:textStyle="bold"
                                android:letterSpacing="0.02"
                                android:textAllCaps="true" />

                            <TextView
                                android:id="@+id/tvRemaining"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="R5,000"
                                android:textSize="22sp"
                                android:textColor="#2ECC71"
                                android:textStyle="bold"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <!-- Progress Section -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="28dp"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="6dp"
                    app:cardBackgroundColor="#F5F9FF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <!-- Progress Header -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="space_between"
                            android:layout_marginBottom="10dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Budget used"
                                android:textSize="14sp"
                                android:textColor="#3A4E66"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvBudgetUsedAmount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="R0"
                                android:textSize="14sp"
                                android:textColor="#C73B3B"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- Progress Bar -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="14dp"
                            android:background="#E0E9F2"
                            android:orientation="horizontal">

                            <View
                                android:id="@+id/viewProgressBar"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="0"
                                android:background="#0A2540" />

                            <View
                                android:id="@+id/viewProgressRemaining"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="100"
                                android:background="#E0E9F2" />
                        </LinearLayout>

                        <!-- Progress Stats -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="space_between"
                            android:layout_marginTop="10dp">

                            <TextView
                                android:id="@+id/tvLeftLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="✓ R5,000 left"
                                android:textSize="13sp"
                                android:textColor="#2ECC71"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvPercentUsed"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0% used"
                                android:textSize="13sp"
                                android:textColor="#5D738B" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Category Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Spending by category"
                    android:textSize="18sp"
                    android:textColor="#0A2540"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <!-- Category Grid Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="28dp">

                    <!-- Groceries Card -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        app:cardCornerRadius="28dp"
                        app:cardElevation="6dp"
                        app:cardBackgroundColor="#FFFFFF">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="18dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🍞 Groceries"
                                android:textSize="14sp"
                                android:textColor="#0A2540"
                                android:textStyle="bold"
                                android:layout_marginBottom="6dp" />

                            <TextView
                                android:id="@+id/tvGroceriesSpent"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="R0"
                                android:textSize="20sp"
                                android:textColor="#1E2F40"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="of R1,500"
                                android:textSize="11sp"
                                android:textColor="#7F95AF"
                                android:layout_marginTop="4dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="✓ on track"
                                android:textSize="11sp"
                                android:textColor="#1D8844"
                                android:textStyle="bold"
                                android:background="#E2F7E9"
                                android:paddingStart="10dp"
                                android:paddingEnd="10dp"
                                android:paddingTop="4dp"
                                android:paddingBottom="4dp"
                                android:layout_marginTop="8dp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Transport Card -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:layout_marginEnd="6dp"
                        app:cardCornerRadius="28dp"
                        app:cardElevation="6dp"
                        app:cardBackgroundColor="#FFFFFF">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="18dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🚗 Transport"
                                android:textSize="14sp"
                                android:textColor="#0A2540"
                                android:textStyle="bold"
                                android:layout_marginBottom="6dp" />

                            <TextView
                                android:id="@+id/tvTransportSpent"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="R0"
                                android:textSize="20sp"
                                android:textColor="#1E2F40"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="of R800"
                                android:textSize="11sp"
                                android:textColor="#7F95AF"
                                android:layout_marginTop="4dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="✓ good"
                                android:textSize="11sp"
                                android:textColor="#1D8844"
                                android:textStyle="bold"
                                android:background="#E2F7E9"
                                android:paddingStart="10dp"
                                android:paddingEnd="10dp"
                                android:paddingTop="4dp"
                                android:paddingBottom="4dp"
                                android:layout_marginTop="8dp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Entertainment Card (Warning) -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        app:cardCornerRadius="28dp"
                        app:cardElevation="6dp"
                        app:cardBackgroundColor="#FFFFFF">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="18dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🍿 Entertainment"
                                android:textSize="14sp"
                                android:textColor="#0A2540"
                                android:textStyle="bold"                                 android:layout_marginBottom="6dp" />

                            <TextView
                                android:id="@+id/tvEntertainmentSpent"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="R0"
                                android:textSize="20sp"
                                android:textColor="#1E2F40"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="of R900"
                                android:textSize="11sp"
                                android:textColor="#7F95AF"
                                android:layout_marginTop="4dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="✓ okay"
                                android:textSize="11sp"
                                android:textColor="#1D8844"
                                android:textStyle="bold"
                                android:background="#E2F7E9"
                                android:paddingStart="10dp"
                                android:paddingEnd="10dp"
                                android:paddingTop="4dp"
                                android:paddingBottom="4dp"
                                android:layout_marginTop="8dp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <!-- Action Buttons Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="8dp">

                    <!-- Add Button -->
                    <Button
                        android:id="@+id/btnAddExpense"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:text="+ Add"
                        android:textSize="14sp"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:background="#0A2540"
                        android:padding="14dp"
                        android:stateListAnimator="@null"
                        android:elevation="6dp" />

                    <!-- History Button -->
                    <Button
                        android:id="@+id/btnHistory"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:layout_marginEnd="6dp"
                        android:text="📋 History"
                        android:textSize="14sp"
                        android:textColor="#0A2540"
                        android:textStyle="bold"
                        android:background="@android:color/transparent"
                        android:backgroundTint="@null"
                        android:padding="14dp"
                        android:elevation="4dp"
                        android:stateListAnimator="@null"
                        style="@style/Widget.Material3.Button.OutlinedButton" />

                    <!-- Graphs Button -->
                    <Button
                        android:id="@+id/btnGraphs"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:text="📊 Graphs"
                        android:textSize="14sp"
                        android:textColor="#0A2540"
                        android:textStyle="bold"
                        android:background="@android:color/transparent"
                        android:backgroundTint="@null"
                        android:padding="14dp"
                        android:elevation="4dp"
                        android:stateListAnimator="@null"
                        style="@style/Widget.Material3.Button.OutlinedButton" />
                </LinearLayout>

                <!-- Footer Note -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Last updated: today • R5,000 monthly budget"
                    android:textSize="12sp"
                    android:textColor="#A7B8C9"
                    android:gravity="center"
                    android:layout_marginTop="28dp"
                    android:layout_marginBottom="8dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>