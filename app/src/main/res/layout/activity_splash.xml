<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    ```
    <!-- Background Decoration -->

    <View
        android:id="@+id/circleDecor"
        android:layout_width="450dp"
        android:layout_height="450dp"
        android:alpha="0.05"
        android:background="@drawable/points_gradient_bg"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Logo Section -->

    <LinearLayout
        android:id="@+id/logoContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Logo Card -->

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/logoCard"
            android:layout_width="120dp"
            android:layout_height="120dp"
            app:cardBackgroundColor="@color/primary"
            app:cardCornerRadius="36dp"
            app:cardElevation="12dp">

            <ImageView
                android:id="@+id/logoImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="24dp"
                android:src="@drawable/cashflow_logo"
                android:scaleType="fitCenter"
                android:contentDescription="Cashflow Pro Logo" />

        </com.google.android.material.card.MaterialCardView>

        <!-- App Name -->

        <TextView
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Cashflow Pro"
            android:textColor="@color/text_primary"
            android:textSize="34sp"
            android:textStyle="bold"
            android:letterSpacing="-0.01" />

        <!-- Subtitle -->

        <TextView
            android:id="@+id/subtitleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Smart Budgeting Made Simple"
            android:textColor="@color/text_secondary"
            android:textSize="16sp" />

    </LinearLayout>
    ```

</androidx.constraintlayout.widget.ConstraintLayout>
